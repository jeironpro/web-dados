{
    "name": "web-dados",
    "version": "1.0.0",
    "description": "Aplicacion interactiva de dados - lanza dados virtuales con soporte multisede y respuesta tactil",
    "type": "module",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint 'js/**/*.js'",
        "lint:css": "stylelint 'css/**/*.css'",
        "format": "prettier --write '**/*.{js,css,html,json,md}'",
        "format:check": "prettier --check '**/*.{js,css,html,json,md}'"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.2.0",
        "stylelint": "^16.2.0",
        "stylelint-config-standard": "^36.0.0",
        "vitest": "^1.2.0"
    },
    "license": "MIT"
}
